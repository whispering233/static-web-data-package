{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "node"
    ],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@whispering233/static-web-data/storage": [
        "packages/core/src/storage/index.ts"
      ],
      "@whispering233/static-web-data": [
        "packages/core/src/index.ts"
      ],
      "@whispering233/static-web-data/schema": [
        "packages/core/src/schema.ts"
      ],
      "@whispering233/static-web-data/export": [
        "packages/core/src/export.ts"
      ],
      "@whispering233/static-web-data-react": [
        "packages/react/src/index.tsx"
      ],
      "@whispering233/static-web-data-dev": [
        "packages/dev/src/index.ts"
      ]
    }
  }
}
