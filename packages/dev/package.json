{
  "name": "@whispering233/static-web-data-dev",
  "version": "0.1.0",
  "description": "Local maintenance CLI, dev server, and storage adapters for static web data.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "bin": {
    "swd": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsup src/index.ts src/cli.ts --format esm --sourcemap && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@whispering233/static-web-data": "^0.1.1",
    "commander": "^14.0.2",
    "hono": "^4.10.7",
    "jiti": "^2.6.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
    "repository": {
    "type": "git",
    "url": "git+https://github.com/whispering233/static-web-data-package.git",
    "directory": "packages/dev"
  }
}
